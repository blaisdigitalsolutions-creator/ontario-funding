# ─────────────────────────────────────────────────────────────────────────────
# Ontario Funding Platform — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git (it's already in .gitignore).

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev
INTERNAL_NOTIFICATION_EMAIL=you@gmail.com

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

ADMIN_TOKEN=change-this-to-a-strong-password

NEXT_PUBLIC_SITE_URL=https://ontariofunding.ca

NEXT_PUBLIC_CONTACT_EMAIL=hello@ontariofunding.ca
NEXT_PUBLIC_CONTACT_PHONE=(647) 000-0000

# Optional:
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/yourname/consultation
# NEXT_PUBLIC_CAL_USERNAME=yourname/consultation
